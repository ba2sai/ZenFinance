import { useState, useEffect } from 'react';
import { Sparkles, TrendingUp, CreditCard, ShieldCheck, Plus, Mail, RefreshCw } from 'lucide-react';
import { motion } from 'framer-motion';
import { useAuthStore } from './store/useAuthStore';
import { useFinanceStore } from './store/useFinanceStore';
import { ImportModal } from './components/ImportModal';
import { analyzeSubscriptions, generateCancellationEmail } from './services/subscriptionService';

function App() {
  const { user, orgId } = useAuthStore();
  const { metrics, expenses, subscribeToExpenses } = useFinanceStore();
  const [isImportOpen, setIsImportOpen] = useState(false);
  const [subs, setSubs] = useState<any[]>([]);
  const [analyzingSubs, setAnalyzingSubs] = useState(false);

  useEffect(() => {
    if (orgId) {
      const unsub = subscribeToExpenses(orgId);
      return () => unsub();
    }
  }, [orgId, subscribeToExpenses]);

  const handleAnalyzeSubs = async () => {
    setAnalyzingSubs(true);
    const result = await analyzeSubscriptions(expenses);
    setSubs(result);
    setAnalyzingSubs(false);
  };

  const handleCancelSub = async (name: string) => {
    const email = await generateCancellationEmail(name);
    alert(`Email de cancelación generado:\n\n${email}`);
  };

  return (
    <div className="p-8 w-full max-w-6xl mx-auto space-y-8 min-h-screen">
      <ImportModal isOpen={isImportOpen} onClose={() => setIsImportOpen(false)} />

      {/* Header */}
      <header className="flex justify-between items-center mb-12">
        <motion.div 
          initial={{ opacity: 0, x: -20 }}
          animate={{ opacity: 1, x: 0 }}
          className="flex items-center gap-3"
        >
          <div className="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center shadow-lg">
            <Sparkles className="text-white w-6 h-6" />
          </div>
          <h1 className="text-3xl font-bold zen-gradient-text tracking-tight">ZenFinance</h1>
        </motion.div>
        
        <div className="flex items-center gap-4">
          <button 
            onClick={() => setIsImportOpen(true)}
            className="glass-card px-4 py-2 text-sm font-bold text-indigo-600 flex items-center gap-2 hover:bg-white/50 transition-all"
          >
            <Plus size={18} />
            Importar
          </button>
          <div className="glass-card px-4 py-2 text-sm font-medium text-slate-600 flex items-center gap-2">
            <span className="w-2 h-2 rounded-full bg-green-400 animate-pulse" />
            {user?.email || 'Demo User'}
          </div>
        </div>
      </header>

      {/* Hero Stats */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { icon: TrendingUp, label: 'Patrimonio Zen', value: `$${metrics.totalPatrimonio.toLocaleString()}`, color: 'indigo' },
          { icon: CreditCard, label: 'Presupuesto Libre', value: `$${metrics.freeBudget.toLocaleString()}`, color: 'purple' },
          { icon: ShieldCheck, label: 'Factor de Paz', value: `${metrics.peaceFactor}%`, color: 'mint' }
        ].map((stat, i) => (
          <motion.div
            key={stat.label}
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ delay: i * 0.1 }}
            className="glass-card p-6 flex flex-col items-center justify-center text-center group hover:scale-105 transition-transform duration-300"
          >
            <div className={`p-3 rounded-full mb-4 group-hover:rotate-12 transition-transform bg-${stat.color}-100 text-${stat.color}-600`}>
              <stat.icon size={24} />
            </div>
            <p className="text-slate-500 text-sm font-medium uppercase tracking-wider">{stat.label}</p>
            <p className="text-3xl font-bold text-slate-800 mt-1">{stat.value}</p>
          </motion.div>
        ))}
      </div>

      {/* Main Content Areas */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-8">
        <motion.div 
          initial={{ opacity: 0, scale: 0.95 }}
          animate={{ opacity: 1, scale: 1 }}
          className="glass-card p-8 min-h-[400px]"
        >
          <h2 className="text-xl font-semibold text-slate-800 mb-6 flex items-center gap-2">
            <Sparkles className="text-indigo-500" size={20} />
            Coach de Vida Financiera
          </h2>
          <div className="space-y-4">
            <div className="bg-indigo-50/50 p-4 rounded-2xl border border-indigo-100 text-indigo-900 leading-relaxed italic">
              {expenses.length > 0 
                ? `"He analizado tus ${expenses.length} movimientos. Tu enfoque en la paz mental es evidente. ¿Quieres que revise si hay suscripciones que están absorbiendo tu energía?"`
                : `"Javier, bienvenido a tu espacio Zen. Importa algunos datos para que pueda empezar a guiarte hacia la tranquilidad financiera."`
              }
            </div>
            {expenses.length > 0 && subs.length === 0 && (
              <button 
                onClick={handleAnalyzeSubs}
                disabled={analyzingSubs}
                className="bg-indigo-600 text-white px-6 py-2 rounded-xl font-bold shadow-lg hover:shadow-indigo-200 transition-all flex items-center gap-2"
              >
                {analyzingSubs ? <RefreshCw className="animate-spin" size={18} /> : <ShieldCheck size={18} />}
                Analizar Suscripciones
              </button>
            )}
          </div>

          {subs.length > 0 && (
            <div className="mt-8 space-y-3">
              <h3 className="text-sm font-bold text-slate-500 uppercase tracking-widest">Sugerencias de Limpieza</h3>
              {subs.map((sub, i) => (
                <motion.div 
                  initial={{ opacity: 0, x: -10 }}
                  animate={{ opacity: 1, x: 0 }}
                  transition={{ delay: i * 0.1 }}
                  key={sub.name} 
                  className="p-4 rounded-2xl bg-white/40 border border-white/60 flex justify-between items-center group shadow-sm"
                >
                  <div>
                    <p className="font-bold text-slate-800">{sub.name}</p>
                    <p className="text-xs text-rose-500 font-medium">Factor Ansiedad: {sub.anxietyLevel}</p>
                  </div>
                  <button 
                    onClick={() => handleCancelSub(sub.name)}
                    className="p-3 bg-rose-50 text-rose-600 rounded-xl opacity-0 group-hover:opacity-100 transition-all hover:bg-rose-100"
                  >
                    <Mail size={18} />
                  </button>
                </motion.div>
              ))}
            </div>
          )}
        </motion.div>

        <motion.div 
          initial={{ opacity: 0, scale: 0.95 }}
          animate={{ opacity: 1, scale: 1 }}
          transition={{ delay: 0.2 }}
          className="glass-card p-8"
        >
          <h3 className="text-xl font-semibold text-slate-800 mb-6 flex items-center gap-2">
            Últimos Movimientos Zen
          </h3>
          <div className="space-y-3 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
             {expenses.length > 0 ? (
               expenses.map((exp, i) => (
                 <motion.div 
                   initial={{ opacity: 0, x: 10 }}
                   animate={{ opacity: 1, x: 0 }}
                   transition={{ delay: i * 0.05 }}
                   key={exp.id || i} 
                   className="flex justify-between items-center p-4 rounded-xl border border-white/50 bg-white/20 hover:bg-white/30 transition-colors"
                 >
                   <div>
                     <p className="font-semibold text-slate-800">{exp.description}</p>
                     <p className="text-xs text-slate-500 font-medium">{exp.category} • {exp.date}</p>
                   </div>
                   <div className="text-right">
                     <p className="font-bold text-slate-800">${exp.amount.toFixed(2)}</p>
                   </div>
                 </motion.div>
               ))
             ) : (
               <div className="text-center py-20">
                  <div className="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <CreditCard className="text-slate-300" size={32} />
                  </div>
                  <p className="text-slate-400 italic">No hay movimientos aún.</p>
               </div>
             )}
          </div>
        </motion.div>
      </div>
    </div>
  );
}

export default App;
