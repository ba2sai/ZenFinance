rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false; // default deny
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /expenses/{id} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && request.resource.data.amount is number;
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    match /incomes/{id} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && request.resource.data.amount is number;
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    match /recurring_expenses/{id} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && request.resource.data.amount is number;
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    match /saving_goals/{id} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    match /advice/{id} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    match /knowledge_base/{id} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    match /audit_logs/{id} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if false; 
    }

    match /categories/{id} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
